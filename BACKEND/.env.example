# Server Configuration
PORT=5000
HOST=0.0.0.0

# CORS Configuration
# Comma-separated list of allowed origins (e.g., http://localhost:5173,https://your-frontend.onrender.com)
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
JWT_SECRET=your-secret-key-here-generate-a-secure-random-string

# MongoDB Configuration
# Your MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# Supabase Configuration
# Your Supabase project URL (no trailing slashes)
SUPABASE_URL=https://your-project.supabase.co
# Supabase Service Role Key (recommended for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Alternatively, you can use the Anon Key (less privileged)
SUPABASE_ANON_KEY=your-anon-key

# Supabase Storage Configuration
# The name of the storage bucket for image uploads (must be created in Supabase dashboard)
SUPABASE_STORAGE_BUCKET=profile-images
