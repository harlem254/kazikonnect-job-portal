# API Configuration
# The base URL for your backend API
# In production on Render, this is automatically set from the backend service's RENDER_EXTERNAL_URL
# For local development, use: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Supabase Configuration
# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase Anon Key (safe for client-side use)
VITE_SUPABASE_ANON_KEY=your-anon-key
# The name of the storage bucket for image uploads (must be created in Supabase dashboard)
VITE_SUPABASE_STORAGE_BUCKET=profile-images
